#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

using_skill_content=$(cat "${PLUGIN_ROOT}/skills/using-supernemawashi/SKILL.md" 2>&1 || echo "Error reading using-supernemawashi skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_skill_escaped=$(escape_for_json "$using_skill_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have supernemawashi.\n\n**Below is the full content of your 'supernemawashi:using-supernemawashi' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${using_skill_escaped}\n</EXTREMELY_IMPORTANT>"

# Append a migration nudge if any profile data is eligible for a format
# upgrade. The detect script iterates its sibling migrations/*.sh --detect
# and prints one line per migration with candidates; if it stays silent,
# the profile set is already current and no nudge is added.
migrate_detect="${PLUGIN_ROOT}/skills/nemawashi-migrate/detect.sh"
if [ -x "$migrate_detect" ]; then
    migrate_output=$("$migrate_detect" 2>/dev/null || true)
    if [ -n "$migrate_output" ]; then
        migrate_escaped=$(escape_for_json "$migrate_output")
        session_context="${session_context}\n\n<MIGRATION_AVAILABLE>\nPending profile-data migrations were detected. Before responding to the user's first request, surface this as a one-line proactive notice suggesting they run \`/supernemawashi:nemawashi-migrate\` when convenient. Do not block the user's request — mention and proceed.\n\n${migrate_escaped}\n</MIGRATION_AVAILABLE>"
    fi
fi

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
